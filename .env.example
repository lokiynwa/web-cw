APP_NAME="Student Affordability Intelligence API"
APP_VERSION="0.1.0"
DEBUG=false
API_PREFIX="/api/v1"
APP_RUNTIME_MODE="rest"
CORS_ALLOWED_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
DATABASE_URL="sqlite:///./student_affordability.db"
API_KEY_ENABLED=false
API_KEY_HEADER_NAME="X-API-Key"
API_KEY_SECRET=""
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AFFORDABILITY_RENT_WEIGHT=0.6
AFFORDABILITY_PINT_WEIGHT=0.2
AFFORDABILITY_TAKEAWAY_WEIGHT=0.2
AFFORDABILITY_RENT_FLOOR_GBP_WEEKLY=80
AFFORDABILITY_RENT_CEILING_GBP_WEEKLY=450
AFFORDABILITY_PINT_FLOOR_GBP=2
AFFORDABILITY_PINT_CEILING_GBP=10
AFFORDABILITY_TAKEAWAY_FLOOR_GBP=5
AFFORDABILITY_TAKEAWAY_CEILING_GBP=25
MCP_HTTP_ENABLED=false
MCP_HTTP_MOUNT_PATH="/mcp"
MCP_HTTP_STATELESS=true
MCP_HTTP_VALIDATE_ORIGIN=true
MCP_HTTP_ALLOWED_ORIGINS=""
MCP_HTTP_ALLOW_REQUESTS_WITHOUT_ORIGIN=true
MCP_HTTP_PUBLIC_READ_TOOLS=true
RUN_MIGRATIONS_ON_START=true
HOST="0.0.0.0"
PORT=8000

# Docker Compose local override example:
# DATABASE_URL="postgresql+psycopg://student:student@postgres:5432/student_affordability"
