APP_NAME="Student Affordability Intelligence API"
APP_VERSION="0.1.0"
DEBUG=false
API_PREFIX="/api/v1"
DATABASE_URL="sqlite:///./student_affordability.db"
API_KEY_ENABLED=false
API_KEY_HEADER_NAME="X-API-Key"
API_KEY_SECRET=""
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Docker Compose local override example:
# DATABASE_URL="postgresql+psycopg://student:student@postgres:5432/student_affordability"
